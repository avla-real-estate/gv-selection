          <a class="loc" href="https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(p.addr+', Greece')}" target="_blank" rel="noopener">Konum</a>
          <button class="yor yorum-btn" type="button" data-yorum-target="${slugifyForYorum(p.name)}">Yorum</button>
        </div>
      </div>`;
    const marker = L.marker([p.lat, p.lng], { icon: makeIcon(p.color), title: p.name })
      .bindPopup(popup, { closeButton: true, autoPan: true });
    if (p.bg) berkayMarkers.push(marker);
    else otherMarkers.push(marker);
  });
  // Expose map filter
  window.AvlaMap = {
    showBerkay() {
      otherMarkers.forEach(m => { try { map.removeLayer(m); } catch(e){} });
      berkayMarkers.forEach(m => m.addTo(map));
      const grp = L.featureGroup(berkayMarkers);
      try { map.fitBounds(grp.getBounds().pad(0.25)); } catch(e){}
    },
    showAll() {
      [...berkayMarkers, ...otherMarkers].forEach(m => m.addTo(map));
      const grp = L.featureGroup([...berkayMarkers, ...otherMarkers]);
      try { map.fitBounds(grp.getBounds().pad(0.15)); } catch(e){}
    }
  };
  // Default: Berkay's 4 only
  setTimeout(() => window.AvlaMap.showBerkay(), 150);
})();
</script>


<script>
(function(){
  function syncStickies(){
    const h = document.querySelector('header')?.offsetHeight || 67;
    document.documentElement.style.setProperty('--header-h', h + 'px');
  }
  syncStickies();
  window.addEventListener('resize', syncStickies);

  const filterButtons = document.querySelectorAll('.filter:not(.filter-external)');
  filterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      setTimeout(() => {
        const target = document.querySelector('section.map-section');
        if (!target) return;
        const offsetInDoc = target.getBoundingClientRect().top + (window.pageYOffset || document.documentElement.scrollTop);
        // Wix HTML widget API — works inside Wix iframes (scrolls parent page)
        if (typeof window.Wix !== 'undefined' && window.Wix.getBoundingRectAndOffsets && window.Wix.scrollTo) {
          window.Wix.getBoundingRectAndOffsets(function(d){
            try { window.Wix.scrollTo(0, (d && d.offsets && d.offsets.y || 0) + offsetInDoc - 80); } catch(e) {}
          });
        }
        // Also do local scroll (works when opened as standalone HTML)
        try { target.scrollIntoView({behavior:'smooth', block:'start'}); } catch(e) {
          window.scrollTo({top: offsetInDoc - 80, behavior: 'smooth'});
        }
      }, 120);
    });
  });
})();
</script>


