<script>
(function() {
  var modal = document.getElementById('yorum-modal');
  if (!modal) return;
  var modalBody = modal.querySelector('.modal-body');
  var modalTitle = modal.querySelector('.modal-title');
  var modalRank = modal.querySelector('.modal-rank-badge');
  var modalTags = modal.querySelector('.modal-tags');
  function open(title, rank, tagsHtml, html) {
    modalTitle.textContent = title;
    if (rank) {
      modalRank.textContent = rank + '. SIRA ÖNERİMİZ';
      modalRank.hidden = false;
    } else {
      modalRank.hidden = true;
    }
    modalTags.innerHTML = tagsHtml || '';
    modalBody.innerHTML = html;
    modal.hidden = false;
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function close() {
    modal.hidden = true;
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.yorum-btn');
    if (btn) {
      var id = btn.getAttribute('data-yorum-target');
      var contentEl = document.getElementById(id);
      if (!contentEl) return;
      // Map popup'tan tıklandığında btn kart içinde değil — content'in kart parentine düş
      var card = btn.closest('.property-body') || contentEl.closest('.property-body');
      var title = card ? ((card.querySelector('.property-title') || {}).textContent || '') : '';
      var rank = contentEl.getAttribute('data-rank');
      var tagsEl = card ? card.querySelector('.tags') : null;
      var tagsHtml = tagsEl ? tagsEl.innerHTML : '';
      open((title || 'Yorum').trim(), rank, tagsHtml, contentEl.innerHTML);
      return;
    }
    if (e.target.matches('[data-close]')) close();
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !modal.hidden) close();
  });
})();
</script>
