  display: inline-flex; align-items: center; justify-content: center; gap: 0.4rem;
  padding: 0.55rem 0.4rem;
  border-radius: var(--radius);
  font-size: 0.66rem; font-weight: 500;
  letter-spacing: 0.08em; text-transform: uppercase;
  cursor: pointer; border: none;
  transition: all 0.2s; text-align: center; font-family: inherit;
  white-space: nowrap;
}
/* 4 + 2 düzeni: ilk 4 buton tek sıra %25, 5. ve 6. butonlar (Bölge + Fizibilite) %50 yan yana */
.actions > .btn:nth-child(n+5) { flex: 1 1 calc(50% - 0.3rem); }
/* === Lüks Disiplin Palette ===
   1 primary (Yorum altın) + 1 secondary (Broşür charcoal) + 4 outline charcoal
   Yeşil/mavi buton katmanından çıktı → rating/badge katmanında kalır
   Hover: hepsi altın dolgu + charcoal yazı (kontrast WCAG uyumlu)
*/
.btn-primary { background: var(--charcoal); color: var(--cream); border: 1px solid var(--charcoal); }
.btn-outline,
.btn-info,
.btn-bolge,
.btn-fizibilite {
  background: transparent; color: var(--charcoal); border: 1px solid var(--charcoal);
}
.btn-yorum { background: var(--charcoal); color: var(--cream); border: 1px solid var(--charcoal); }
/* Tek hover: AÇIK BEJ (cream) dolgu + charcoal yazı — filter bar şeridi ile aynı ton */
.btn-primary:hover,
.btn-outline:hover,
.btn-info:hover,
.btn-bolge:hover,
.btn-fizibilite:hover,
.btn-yorum:hover {
  background: var(--cream); color: var(--charcoal); border-color: var(--charcoal);
}
@media (max-width: 768px) {
  .btn { font-size: 0.6rem; padding: 0.45rem 0.3rem; flex: 1 1 calc(50% - 0.3rem); }
  .actions > .btn:nth-child(n+5) { flex: 1 1 calc(50% - 0.3rem); }
