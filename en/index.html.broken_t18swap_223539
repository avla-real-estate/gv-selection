  'yorum-t18-city-residences': 'Athens Centre',
  'yorum-ap37-suites': 'Agios Dimitrios'
};

// Her property kartına data-subregion + data-neighborhood ata
document.querySelectorAll('.property').forEach(p => {
  const yorumBtn = p.querySelector('.yorum-btn');
  if (yorumBtn) {
    const key = yorumBtn.dataset.yorumTarget;
    const sr = subRegionMap[key];
    if (sr) p.dataset.subregion = sr;
    const nbh = neighborhoodMap[key];
    if (nbh) p.dataset.neighborhood = nbh;
  }
});

// Group-head <small>'ı görünür kartlara göre tazele (mahalleler + proje sayısı)
function updateGroupHeads() {
  document.querySelectorAll('.group-head').forEach(head => {
    const grid = head.nextElementSibling;
    if (!grid || !grid.classList.contains('property-grid')) return;
    const visibleCards = grid.querySelectorAll('.property:not(.hidden)');
    if (!visibleCards.length) return;
    const seen = new Set();
    const nbhs = [];
    visibleCards.forEach(c => {
      const n = c.dataset.neighborhood;
      if (n && !seen.has(n)) { seen.add(n); nbhs.push(n); }
    });
    const count = visibleCards.length;
    const small = head.querySelector('h3 small');
    if (small) {
      small.textContent = (nbhs.length ? nbhs.join(' · ') + ' · ' : '') + `${count} Project${count > 1 ? 's' : ''}`;
    }
  });
}

function updateRegionChips() {
  document.querySelectorAll('.chip[data-subregion]').forEach(chip => {
    const sr = chip.dataset.subregion;
    const visibleCount = document.querySelectorAll(`.property[data-subregion="${sr}"]:not(.hidden)`).length;
    chip.toggleAttribute('aria-disabled', visibleCount === 0);
  });
}

// Chip click → o alt-bölgenin ilk görünür kartına scroll
document.querySelectorAll('.chip[data-subregion]').forEach(chip => {
  chip.addEventListener('click', () => {
    if (chip.getAttribute('aria-disabled') === 'true') return;
    const first = document.querySelector(`.property[data-subregion="${chip.dataset.subregion}"]:not(.hidden)`);
    if (!first) return;
    const headerH = document.querySelector('header')?.offsetHeight || 67;
    const filterH = document.querySelector('.filters-bar')?.offsetHeight || 60;
    const y = first.getBoundingClientRect().top + window.pageYOffset - headerH - filterH - 16;
    window.scrollTo({ top: y, behavior: 'smooth' });
  });
});

// Default: Berkay selection
applyFilter('berkay');
updateRegionChips();
updateGroupHeads();
</script>

