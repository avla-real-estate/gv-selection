<script>
const filterButtons = document.querySelectorAll('.filter:not(.filter-external)');
const properties = document.querySelectorAll('.property');

function applyFilter(f) {
  filterButtons.forEach(b => b.classList.toggle('active', b.dataset.filter === f));
  properties.forEach(p => {
    const isInSelection = p.dataset.berkaySelection === '1';
    let show = (f === 'all') || (f === 'berkay' && isInSelection);
    p.classList.toggle('hidden', !show);
  });
  document.querySelectorAll('.property-grid').forEach(grid => {
    const visibleCards = grid.querySelectorAll('.property:not(.hidden)').length;
    const head = grid.previousElementSibling;
    if (head && head.classList.contains('group-head')) {
      head.classList.toggle('hidden', visibleCards === 0);
      grid.classList.toggle('hidden', visibleCards === 0);
    }
  });
  // Hero stats mode swap
  document.body.classList.toggle('mode-avla', f === 'all');
}

filterButtons.forEach(btn => {
  btn.addEventListener('click', () => {
    applyFilter(btn.dataset.filter);
    // Map filter sync (scroll handled by other script below)
    if (window.AvlaMap) {
      if (btn.dataset.filter === 'all') window.AvlaMap.showAll();
      else window.AvlaMap.showBerkay();
    }
    // Update region chip availability (dimmed if region has no visible card)
    updateRegionChips();
    // Refresh group-head subtitles (neighborhoods + count)
    updateGroupHeads();
  });
});

// Property → sub-region eşlemesi (harita pin renkleriyle uyumlu)
const subRegionMap = {
  'yorum-etolikou-seafront': 'pire',
  'yorum-ag-ioannis-renti': 'pire',
  'yorum-mikrolimano-38n': 'pire',
  'yorum-heritage-piraeus': 'pire',
  'yorum-metropolitan-apartment': 'merkez',
  'yorum-minoas-athens': 'merkez',
  'yorum-aurora-residences': 'merkez',
