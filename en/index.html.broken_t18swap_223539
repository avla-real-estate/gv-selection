<script>
  (function () {
    var MAP = {
      'Sorunuzu yazın…':         'Type your question…',
      'Sorunuzu yazın...':       'Type your question…',
      'Tam ekran':               'Full screen',
      'Küçült':                  'Minimize',
      'Kapat':                   'Close',
      'Sohbeti PDF olarak indir':'Download chat as PDF',
      'Bir sorum daha var':      'I have another question',
      'Görüşümü paylaşayım':     'Share my feedback',
      'Teşekkürler 👋':           'Thank you 👋',
      'Bir hata oldu, tekrar dener misiniz?': 'Something went wrong, please try again.',
      'Tekrar hoş geldiniz 👋 Kaldığınız yerden devam edelim mi?':
                                 'Welcome back 👋 Shall we pick up where we left off?',
      'Gönder':                  'Send'
    };
    function patch(root) {
      if (!root) return;
      var w = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);
      var n;
      while ((n = w.nextNode())) {
        var t = (n.textContent || '').trim();
        if (t && MAP[t]) n.textContent = MAP[t];
      }
      root.querySelectorAll('[placeholder]').forEach(function (el) {
        var v = el.getAttribute('placeholder');
        if (v && MAP[v]) el.setAttribute('placeholder', MAP[v]);
      });
      root.querySelectorAll('[aria-label]').forEach(function (el) {
        var v = el.getAttribute('aria-label');
        if (v && MAP[v]) el.setAttribute('aria-label', MAP[v]);
      });
      root.querySelectorAll('[title]').forEach(function (el) {
        var v = el.getAttribute('title');
        if (v && MAP[v]) el.setAttribute('title', MAP[v]);
      });
    }
    function findAthenaShadow() {
      var divs = document.body.querySelectorAll('div');
      for (var i = divs.length - 1; i >= 0; i--) {
        var d = divs[i];
        if (d.shadowRoot && d.shadowRoot.querySelector('#a-launch, #a-teaser, #a-panel')) {
          return d.shadowRoot;
        }
      }
      return null;
    }
    var tries = 0;
    var iv = setInterval(function () {
      var sr = findAthenaShadow();
      if (sr) {
        patch(sr);
        new MutationObserver(function () { patch(sr); })
          .observe(sr, { childList: true, subtree: true, characterData: true, attributes: true });
        clearInterval(iv);
      } else if (++tries > 30) {
        clearInterval(iv);
      }
    }, 600);
  })();
</script>
