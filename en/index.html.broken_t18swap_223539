.btn-primary:hover,
.btn-outline:hover,
.btn-info:hover,
.btn-bolge:hover,
.btn-fizibilite:hover,
.btn-yorum:hover {
  background: var(--cream); color: var(--charcoal); border-color: var(--charcoal);
}
@media (max-width: 768px) {
  .btn { font-size: 0.6rem; padding: 0.45rem 0.3rem; flex: 1 1 calc(50% - 0.3rem); }
