  }
  function slugifyForYorum(name) {
    var map = {'ç':'c','ğ':'g','ı':'i','ö':'o','ş':'s','ü':'u','Ç':'c','Ğ':'g','İ':'i','I':'i','Ö':'o','Ş':'s','Ü':'u'};
    var s = name.toLowerCase().replace(/[çğıöşüÇĞİIÖŞÜ]/g, function(c){ return map[c] || c; });
    s = s.replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    return 'yorum-' + s;
  }
  
  const berkayMarkers = [];
  const otherMarkers = [];
  data.forEach(p => {
    const broLink = p.brochure ? `<a class="bro" href="../brochures/${p.brochure}" target="_blank" rel="noopener">Brochure</a>` : (p.ilan ? `<a class="bro" href="${p.ilan}" target="_blank" rel="noopener">Listing</a>` : '');
