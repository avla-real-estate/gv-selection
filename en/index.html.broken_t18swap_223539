  'yorum-venus-athens-riviera': 'riviera',
  'yorum-the-one-glyfada': 'riviera',
  'yorum-south-agios-dimitrios': 'agios-dimitrios',
  'yorum-the-north-village': 'kifisia',
  'yorum-terrace-heights': 'peristeri',
  'yorum-l22-student-housing': 'keramikos',
  'yorum-t18-city-residences': 'merkez',
  'yorum-ap37-suites': 'agios-dimitrios'
};

// Property → mahalle eşlemesi (group-head <small> içinde dinamik göstermek için)
const neighborhoodMap = {
  'yorum-etolikou-seafront': 'Pire',
  'yorum-ag-ioannis-renti': 'Renti',
  'yorum-mikrolimano-38n': 'Mikrolimano',
  'yorum-heritage-piraeus': 'Pire',
  'yorum-metropolitan-apartment': 'Ampelokipi',
